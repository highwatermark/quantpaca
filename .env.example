# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Alpaca broker credentials are read from .env only and are never persisted to data/db.json.
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
TRADING_MODE="paper"
LIVE_TRADING_ENABLED="false"

# Required for POST /api/sync and broker-affecting command routes.
ADMIN_API_TOKEN="change-me"

# Telegram command plane. Roles use chat/user ID to role mappings.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_ROLES="123456789:admin"
TELEGRAM_RUNTIME="long_polling_ready"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
