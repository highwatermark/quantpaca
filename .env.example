# ANTHROPIC_API_KEY: Required for Claude API calls (thesis analysis + web-search
# sentiment). Get one at https://platform.claude.com/ — keys start with sk-ant-.
# If unset, AI analysis falls back to simulated values.
ANTHROPIC_API_KEY=""

# Alpaca broker credentials are read from .env only and are never persisted to data/db.json.
ALPACA_API_KEY=""
ALPACA_SECRET_KEY=""
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
# Alpaca market data host (separate from the trading API host).
ALPACA_DATA_URL="https://data.alpaca.markets"
TRADING_MODE="paper"
LIVE_TRADING_ENABLED="false"

# Required for POST /api/sync and broker-affecting command routes.
# The server REFUSES TO BOOT while this is set to the placeholder value.
# Generate one with: openssl rand -hex 24
ADMIN_API_TOKEN="change-me"

# Optional, lower-privilege credential for GET /api/* read routes (trades,
# portfolio, audit, etc. -- everything except /api/health, which stays
# unauthenticated for Docker healthchecks/uptime monitors). Either this OR
# ADMIN_API_TOKEN is accepted on reads. If unset, reads fall back to
# requiring ADMIN_API_TOKEN (a boot warning reminds you to set this).
# The server REFUSES TO BOOT if this is set to a placeholder or short value.
# Generate one with: openssl rand -hex 24
QUANTPACA_READ_TOKEN=""

# Server-side Gmail refresh-token auth (Phase 2 follow-up) -- lets SCHEDULED
# (unattended) sync cycles read Gmail without a browser session. All three
# are required together (the server REFUSES TO BOOT if only 1 or 2 of the 3
# are set); leave all three empty/unset to disable the broker (Gmail
# ingestion then only works on a manual sync with a browser-supplied OAuth
# token, same as before this feature). Obtain all three with:
#   node scripts/get-google-refresh-token.mjs
# See docs/OPS_RUNBOOK.md "Connect Gmail" for the full walkthrough. These are
# ops secrets, same class as ALPACA_API_KEY/ALPACA_SECRET_KEY above -- never
# commit real values, never logged by the server.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# Telegram command plane. Roles use chat/user ID to role mappings.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_ROLES="123456789:admin"
TELEGRAM_RUNTIME="long_polling_ready"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Risk limits — loaded ONCE at process start; not configurable at runtime by design
# (docs/LOOP_ARCHITECTURE.md "Structural Immutability of Risk Thresholds").
# Defaults are conservative placeholders; set values matching your risk appetite.
QUANTPACA_MAX_DAILY_LOSS="500"
QUANTPACA_MAX_DAILY_TRADES="10"
QUANTPACA_MAX_OPEN_POSITIONS="10"
QUANTPACA_MIN_BUYING_POWER="100"
QUANTPACA_MAX_DAILY_LOSS_PERCENT="3"
QUANTPACA_MAX_DRAWDOWN_FROM_PEAK_PERCENT="10"
QUANTPACA_MAX_DRAWDOWN_FROM_BASELINE_PERCENT="15"
# Optional: account baseline for the baseline-drawdown breaker. Unset = check skipped.
QUANTPACA_BASELINE_EQUITY=""
